{
  "name": "@bolte/critical-path",
  "version": "1.0.0",
  "description": "A critical path analysis tool powered by rust",
  "keywords": [
    "ci",
    "cli",
    "critical-path",
    "frontend",
    "performance",
    "rust"
  ],
  "homepage": "https://github.com/alexfigliolia/critical-path-check#readme",
  "bugs": {
    "url": "https://github.com/alexfigliolia/critical-path-check/issues"
  },
  "license": "MIT",
  "author": "Alex Figliolia",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/alexfigliolia/critical-path-check.git"
  },
  "files": [
    "lib/**/*.?({c,m}){t,j}s"
  ],
  "main": "./lib/index.cjs",
  "types": "./lib/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    }
  },
  "scripts": {
    "bench": "yarn tsx benchmark/bench.ts",
    "build:dev": "yarn run cargo-build && tsdown",
    "build:release": "yarn run cargo-build --release && tsdown",
    "cargo-build": "cargo build --workspace --message-format=json-render-diagnostics > cargo.log",
    "cross": "yarn run cross-build --release",
    "cross-build": "cross build --workspace --message-format=json-render-diagnostics > cross.log",
    "cross:dev": "yarn run cross-build && tsdown",
    "cross:release": "yarn build:release && yarn run cross",
    "debug": "yarn run cargo-build",
    "dryrun": "gh workflow run publish.yml -f dryrun=true",
    "format:toml": "taplo lint && taplo format",
    "lint:all": "yarn lint:rust && yarn lint:ts",
    "lint:rust": "cargo clippy --fix --allow-dirty && yarn format:toml",
    "lint:rust:ci": "cargo clippy --fix",
    "lint:ts": "yarn oxlint --type-aware --type-check --report-unused-disable-directives --fix && yarn oxfmt",
    "postcargo-build": "neon dist < cargo.log",
    "postcross-build": "neon dist -m ./target < cross.log",
    "prepack": "neon update && yarn build:release",
    "release": "gh workflow run release.yml -f dryrun=false -f version=patch",
    "run:dev": "cargo run --package critical-path-check --bin critical-path-check",
    "test": "yarn build:dev && ava",
    "version": "neon bump --binaries platforms && git add ."
  },
  "dependencies": {
    "@neon-rs/load": "^0.1.82"
  },
  "devDependencies": {
    "@neon-rs/cli": "^0.1.82",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^25.6.0",
    "ava": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.14.0",
    "oxlint-tsgolint": "^0.21.0",
    "tinybench": "^6.0.0",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "yarn lint:ts"
    ],
    "*.rs": [
      "yarn lint:rust"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "files": [
      "__test__/**/*"
    ],
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ],
    "timeout": "2m",
    "workerThreads": false
  },
  "neon": {
    "type": "library",
    "org": "@bolte",
    "prefix": "critical-path-",
    "platforms": "common",
    "load": "./externals/load.ts"
  }
}
