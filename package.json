{
  "name": "critical-path-check",
  "version": "1.0.3",
  "description": "A critical path analysis tool powered by rust",
  "keywords": [
    "ci",
    "cli",
    "critical-path",
    "frontend",
    "performance",
    "rust"
  ],
  "homepage": "https://github.com/alexfigliolia/critical-path-check#readme",
  "bugs": {
    "url": "https://github.com/alexfigliolia/critical-path-check/issues"
  },
  "license": "MIT",
  "author": "Alex Figliolia",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/alexfigliolia/critical-path-check.git"
  },
  "files": [
    "dist",
    "externals",
    "internals",
    "Cargo.lock",
    "Cargo.toml",
    "install.sh"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "bench": "yarn tsx benchmark/bench.ts",
    "build:cli": "yarn build:rust && yarn install:rust",
    "build:rust": "cargo build --release",
    "build:rust:dev": "cargo build",
    "build:ts": "tsdown",
    "format:toml": "taplo lint && taplo format",
    "install:rust": "cargo install --path .",
    "lint:all": "yarn lint:rust && yarn lint:ts",
    "lint:rust": "cargo clippy --fix --allow-dirty && yarn format:toml",
    "lint:rust:ci": "cargo clippy --fix",
    "lint:ts": "yarn oxlint --type-aware --type-check --report-unused-disable-directives --fix && yarn oxfmt",
    "postinstall": "chmod +x install.sh && ./install.sh",
    "release": "tsx ./release/run.ts",
    "run:dev": "cargo run --bin critical-path-check",
    "test": "yarn build:cli && ava"
  },
  "dependencies": {
    "@figliolia/child-process": "^1.0.4",
    "@figliolia/semver": "^1.0.0"
  },
  "devDependencies": {
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^25.6.0",
    "ava": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.14.0",
    "oxlint-tsgolint": "^0.21.0",
    "tinybench": "^6.0.0",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "yarn lint:ts"
    ],
    "*.rs": [
      "yarn lint:rust"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "files": [
      "__test__/**/*"
    ],
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ],
    "timeout": "2m",
    "workerThreads": false
  }
}
